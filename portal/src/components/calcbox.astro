---
// src/components/calcbox.astro
// Destructure the "mode" prop from the page calling this component
const { mode = "scientific" } = Astro.props;
const isGraphing = mode === "graphing";
---

<div class="container" data-mode={mode}>
    
    {isGraphing ? (
        <h1>Arithmos Graphing Engine</h1>
        <p>Enter a function of x and its bounds to evaluate (e.g., <code>12x^2+3x-5</code>) with the Min Max and Steps values:</p>
    ) : (
        <h1>Arithmos Math Engine</h1>
        <p>Enter a mathematical expression to evaluate (e.g., <code>3+5*2</code>):</p>
    )}
    
    <div class="input-group">
        <input type="text" id="expressionInput" placeholder="Type expression here..." autocomplete="off">
        <button id="evaluateBtn">Evaluate</button>
    </div>

    {isGraphing && (
        <div class="graph-inputs">
            <input type="text" id="xMinInput" placeholder="xMin (e.g. 0)" autocomplete="off" />
            <input type="text" id="xMaxInput" placeholder="xMax (e.g. 10)" autocomplete="off" />
            <input type="text" id="xCountInput" placeholder="Steps (e.g. 5)" autocomplete="off" />
        </div>
    )}

    <div id="resultContainer" class="result-box hidden">
        <h3>Result:</h3>
        <p id="resultText"></p>
        <div id="tableContainer"></div>
    </div>
</div>

<style>
    .container {
        background-color: #ffffff;
        padding: 2.5rem;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        max-width: 600px;
        width: 100%;
        box-sizing: border-box;
    }

    h1 {
        margin-top: 0;
        font-size: 1.8rem;
        color: #333;
    }

    p {
        color: #666;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .input-group {
        display: flex;
        gap: 10px;
        margin-top: 1.5rem;
    }

    #expressionInput {
        flex: 1;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 1rem;
    }

    #evaluateBtn {
        background-color: #007bff;
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 6px;
        font-weight: bold;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    #evaluateBtn:hover {
        background-color: #0056b3;
    }

    .graph-inputs {
        display: flex;
        gap: 10px;
        margin-top: 1rem;
        width: 100%;
        box-sizing: border-box;
        flex-wrap: wrap;
    }

    .graph-inputs input {
        flex: 1;
        min-width: 0;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 0.9rem;
        box-sizing: border-box;
    }

    .result-box {
        margin-top: 1.5rem;
        padding: 15px;
        background-color: #f8f9fa;
        border-left: 4px solid #007bff;
        border-radius: 4px;
    }

    .hidden {
        display: none;
    }

    :global(.points-table) {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

    :global(.points-table th), :global(.points-table td) {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
    }

    :global(.points-table th) {
        background-color: #f1f1f1;
    }
</style>

<script>
    function runEvaluationEngine() {
        const container = document.querySelector('.container');
        
        const evaluateBtn = document.getElementById('evaluateBtn');
        const expressionInput = document.getElementById('expressionInput');

        if (!evaluateBtn || !expressionInput || !container) return;

        evaluateBtn.replaceWith(evaluateBtn.cloneNode(true));
        const activeBtn = container.querySelector('#evaluateBtn');

        if (activeBtn) {
            activeBtn.addEventListener('click', () => {
                sendExpression();
            });

            expressionInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    sendExpression();
                }
            });
        }
    }

    async function sendExpression() {
    const container = document.querySelector('.container');
    const mode = container ? container.getAttribute('data-mode') : 'scientific';

    const inputElement = document.getElementById('expressionInput') as HTMLInputElement;
    const xMinElement = document.getElementById('xMinInput') as HTMLInputElement;
    const xMaxElement = document.getElementById('xMaxInput') as HTMLInputElement;
    const xCountElement = document.getElementById('xCountInput') as HTMLInputElement;
    const resultContainer = document.getElementById('resultContainer');
    const resultText = document.getElementById('resultText');
    const tableContainer = document.getElementById('tableContainer');

    if (!inputElement || !resultText) return;
    const expressionValue = inputElement.value.trim();

    const xMinValue = xMinElement ? xMinElement.value.trim() : "0";
    const xMaxValue = xMaxElement ? xMaxElement.value.trim() : "0";
    const xCountValue = xCountElement ? xCountElement.value.trim() : "0";

    if (!expressionValue) {
        alert("Please enter a valid expression.");
        return;
    }

    try {
    resultText.innerText = "Evaluating...";
    if (tableContainer) tableContainer.innerHTML = "";

    let calcType = "s";

    if (mode === "graphing") {
        calcType = "g";
    }
    if (mode === "scientific") {
        calcType = "s";
    }

    const response = await fetch('/api/evaluate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
            mode: calcType,
            expression: expressionValue, 
            xMin: xMinValue, 
            xMax: xMaxValue, 
            xCount: xCountValue 
        })
    });

            const data = await response.json();

            if (response.ok && data.success) {
                resultContainer?.classList.remove('hidden');
                resultText.innerHTML = `<strong>Input:</strong> ${data.input}<br><strong>Output:</strong> ${data.result}`;
                
                if (data.points && tableContainer) {
                    let tableHtml = "<table class='points-table'><thead><tr><th>X Value</th><th>Y Value</th></tr></thead><tbody>";
                    for (const pt of data.points) {
                        tableHtml += `<tr><td>${pt.x}</td><td>${pt.y}</td></tr>`;
                    }
                    tableHtml += "</tbody></table>";
                    tableContainer.innerHTML = tableHtml;
                }
            } else {
                resultText.innerText = `Error: ${data.error || "Something went wrong"}`;
            }
        } catch (error) {
            console.error("Fetch operation failed:", error);
            resultText.innerText = "Error connecting to the math server backend.";
        }
    }

    runEvaluationEngine();
document.addEventListener('astro:page-load', runEvaluationEngine);
</script>