---
// src/pages/index.astro
import Layout from '../layouts/layout.astro';
---

<Layout title="Home | Explicanda">
    
    <div class="button-grid">
        
        <div class="menu-item">
            <a href="/calculators/scientific" class="calc-btn">
                </a>
            <span class="btn-label">Scientific Calculator</span>
        </div>

        <div class="menu-item">
            <a href="/calculators/graphing" class="calc-btn">
                </a>
            <span class="btn-label">Graphing Calculator</span>
        </div>

    </div>

</Layout>

<style>
    /* Grid layout to hold the menu items side-by-side */
    .button-grid {
        display: flex;
        gap: 3rem;
        padding: 2rem;
        max-width: 800px;
        width: 100%;
        box-sizing: border-box;
    }

    /* Container to stack the large button and its label vertically */
    .menu-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* The exact large button design you liked from before */
    .calc-btn {
        width: 100%;
        height: 200px; /* Massive dashboard height */
        background-color: #ffffff;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        transition: all 0.2s ease-in-out;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
    }

    /* Text label positioned cleanly underneath the large button */
    .btn-label {
        margin-top: 1rem;
        font-size: 1.2rem;
        font-weight: 600;
        color: #4a5568;
        transition: color 0.2s ease-in-out;
    }

    /* Hover interactions tied directly to the item components */
    .menu-item:hover .calc-btn {
        transform: translateY(-4px);
        border-color: #007bff;
        box-shadow: 0 10px 15px -3px rgba(0, 123, 255, 0.1);
    }

    .menu-item:hover .btn-label {
        color: #007bff;
    }

    .calc-btn:active {
        transform: translateY(-1px);
    }

    /* Clean vertical layout for mobile screens */
    @media (max-width: 600px) {
        .button-grid {
            flex-direction: column;
            gap: 2rem;
        }
    }
</style>